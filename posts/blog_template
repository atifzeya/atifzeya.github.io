<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><!-- CHANGE THIS: Post Title --> — YourName</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=JetBrains+Mono:wght@300;400&family=Karla:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="../style.css"/>
  <style>
    .post-wrap  { max-width: 780px; margin: 0 auto; padding: 0 2rem 6rem; }
    .back-link  { display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); text-decoration: none; margin-bottom: 3rem; transition: color 0.2s; }
    .back-link:hover { color: var(--accent); }
    .post-hero  { width: 100%; aspect-ratio: 3/2; object-fit: cover; display: block; margin-bottom: 2.5rem; filter: grayscale(15%); }
    .post-meta  { font-family: var(--mono); font-size: 0.63rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); margin-bottom: 1rem; }
    .post-title { font-family: var(--serif); font-size: clamp(2.2rem,5vw,3.8rem); font-weight: 300; font-style: italic; line-height: 1.1; margin-bottom: 2.2rem; }
    .post-body  { font-size: 1.05rem; line-height: 1.95; color: rgba(226,221,214,0.85); }
    .post-body p { margin-bottom: 1.7rem; }

    /* Full-width photo */
    .photo      { width: 100%; margin: 2.5rem 0; }
    .photo img  { width: 100%; display: block; object-fit: cover; filter: grayscale(15%); transition: filter 0.4s; }
    .photo img:hover { filter: grayscale(0%); }
    .photo figcaption { font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.1em; color: var(--muted); padding-top: 0.6rem; }

    /* Two photos side by side */
    .photo.duo  { display: grid; grid-template-columns: 1fr 1fr; gap: 4px; }
    .photo.duo figcaption { grid-column: span 2; }

    /* Three photos in a row */
    .photo.trio { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 4px; }
    .photo.trio figcaption { grid-column: span 3; }

    /* Pull quote */
    .pull-quote { font-family: var(--serif); font-size: 1.5rem; font-style: italic; line-height: 1.55; color: var(--accent); border-left: 2px solid var(--accent); padding: 0.5rem 0 0.5rem 1.5rem; margin: 2.5rem 0; }

    /* Post navigation */
    .post-nav { display: flex; justify-content: space-between; margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border); }
    .post-nav a { font-family: var(--mono); font-size: 0.63rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.2s; }
    .post-nav a:hover { color: var(--accent); }

    @media (max-width: 600px) {
      .photo.duo, .photo.trio { grid-template-columns: 1fr; }
      .photo.duo figcaption, .photo.trio figcaption { grid-column: span 1; }
    }
  </style>
</head>
<body>
<div id="cursor"></div>
<nav id="navbar">
